# Visual Studio 2017+ cache
.vs/

# --- TOOLS EXCEPTIONS ---
# We keep specific essential tools in the bin folder
!bin/WinDivert.dll
!bin/WinDivert64.sys
!bin/cygwin1.dll
!bin/winws.exe

# Ignore all other binaries globally
*.dll
*.pdb
*.sys
*.exe
*.msi
*.msix
*.zip
*.7z

# --- PROJECT-SPECIFIC EXCEPTIONS ---
# Allow the main source code binaries if specifically needed
!/bin/
!bin/WinDivert.dll
!bin/WinDivert64.sys
!bin/cygwin1.dll
!bin/winws.exe
